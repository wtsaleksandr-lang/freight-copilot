# Anthropic API key — used by Claude to parse rate pages into structured JSON.
# Get one from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Local SQLite database file (created automatically on first run).
DATABASE_FILE=./data/freight-copilot.db

# Set to true to drive a real Chrome browser instead of Playwright's bundled
# Chromium. Bypasses bot-detection on hostile carrier portals (Hapag, CMA, etc.).
# Requires running setup-chrome-debug.ps1 once and launching the
# "Chrome (Freight Copilot)" desktop shortcut before each session.
# Default: false (uses bundled Chromium).
USE_REAL_CHROME=false
