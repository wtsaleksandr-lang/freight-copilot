# Anthropic API key — used by Claude to parse rate pages into structured JSON.
# Get one from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Local SQLite database file (created automatically on first run).
DATABASE_FILE=./data/freight-copilot.db

# Set to true to drive a real Chrome browser instead of Playwright's bundled
# Chromium. Bypasses bot-detection on hostile carrier portals (Hapag, CMA, etc.).
# Requires running setup-chrome-debug.ps1 once and launching the
# "Chrome (Freight Copilot)" desktop shortcut before each session.
# Default: false (uses bundled Chromium).
USE_REAL_CHROME=false

# Optional: enable HTTP Basic auth on the dashboard. STRONGLY recommended any
# time the server is exposed beyond localhost (--host 0.0.0.0, Tailscale,
# tunnels). Set BOTH to enable. See docs/remote-access.md.
# BASIC_AUTH_USER=alex
# BASIC_AUTH_PASS=replace-with-a-long-random-password

# Optional: base URL of a running DelayPredict instance (separate repo,
# wtsaleksandr-lang/delaypredict). When set, the Shipments tab joins each
# row with DelayPredict's tracking status by personal_ref → refId. Each
# row gets a colored status dot (green=on track, yellow=watch, red=delayed,
# orange=cancelled, blue=delivered, gray=not tracked) plus a click-to-detail
# modal with ETA, delay days, vessel info, and a "Refresh tracking" button
# that proxies to DelayPredict. Leave unset to disable.
# DELAYPREDICT_URL=http://localhost:5001
