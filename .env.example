# AI provider. Anthropic is the default.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Optional env fallbacks for other providers (in-app encrypted keys take precedence).
# GEMINI_API_KEY=...
# OPENAI_API_KEY=...
# XAI_API_KEY=...
# DEEPSEEK_API_KEY=...

# Master key that encrypts app-stored provider credentials (AES-256-GCM).
# 64 hex chars OR a 32-byte base64 value. MUST be set in production — the app
# refuses to auto-generate an ephemeral key there. Distinct from SESSION_SECRET.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRETS_MASTER_KEY=

# Persistent standard PostgreSQL database. Required. Works with any standard
# Postgres: Replit-managed, Neon-hosted, or self-hosted. SSL is taken from the
# URL's sslmode (use ?sslmode=require for managed cloud Postgres).
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Production listener. Replit normally provides PORT automatically.
HOST=0.0.0.0
PORT=3000

# Optional model overrides.
AI_MODEL=claude-haiku-4-5-20251001
AI_MODEL_FALLBACK=claude-sonnet-4-6

# Desktop-only browser mode. Requires Chrome running with remote debugging.
# Keep false on Replit or another hosted server.
USE_REAL_CHROME=false

# Strongly recommended whenever the app is reachable outside localhost.
BASIC_AUTH_USER=alex
BASIC_AUTH_PASS=replace-with-a-long-random-password

# Optional integration with a separate DelayPredict deployment.
# DELAYPREDICT_URL=https://your-delaypredict.example
