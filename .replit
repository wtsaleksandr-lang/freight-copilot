modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
USE_REAL_CHROME = "false"
# DATABASE_URL is set as a Replit Secret on the deployment (Neon Postgres
# connection string). Persists across redeploys — file-based storage was
# wiped on every redeploy because Reserved VM disks don't persist.

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm tsx src/index.ts serve --port 5000 --host 0.0.0.0"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["pnpm", "tsx", "src/index.ts", "serve", "--port", "5000", "--host", "0.0.0.0"]
build = ["pnpm", "install"]
