{
  "name": "freight-copilot",
  "version": "0.0.1",
  "description": "Single-user freight-forwarding automation workspace for rates, shipments, reporting, and email assistance",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/production.js",
    "start:desktop": "pnpm build && node dist/production.js",
    "deploy:prepare": "pnpm install --frozen-lockfile && pnpm build",
    "test": "node --import tsx --test src/**/*.test.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@kenjiuno/msgreader": "^1.28.0",
    "commander": "^14.0.3",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
